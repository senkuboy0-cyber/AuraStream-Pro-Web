# AuraStream Pro Web - Production Environment

# Server Configuration
PORT=3001
NODE_ENV=production

# MongoDB Connection (Replace with your MongoDB Atlas URI)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aurastream

# GitHub API Token (for fetching repositories)
GITHUB_TOKEN=ghp_your_github_token_here

# Security
JWT_SECRET=generate_a_strong_random_secret_here
SESSION_SECRET=generate_another_strong_random_secret_here

# CORS
CORS_ORIGIN=https://your-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Plugin Settings
PLUGIN_TIMEOUT_MS=30000
PLUGIN_MEMORY_LIMIT_MB=128

# Logging
LOG_LEVEL=info
